{
  "name": "vsnip-check",
  "displayName": "vsnip-check",
  "description": "Syntax highlighting and error reporting for .nip pickit files",
  "version": "1.3.0",
  "author": "theBGuy <theBGuy.github@gmail.com>",
  "publisher": "theBGuy",
  "repository": "https://github.com/theBGuy/vsnip-check",
  "engines": {
    "vscode": "^1.85.5"
  },
  "categories": [
    "Programming Languages"
  ],
  "license": "MIT",
  "icon": "logo.png",
  "activationEvents": [
    "onDidOpenTextDocument",
    "onDidSaveTextDocument",
    "onDidChangeActiveTextEditor",
    "onDidOpenTextDocument",
    "onStartupFinished",
    "onDidCloseTextDocument",
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./dist/diagnostics.js",
  "contributes": {
    "languages": [
      {
        "id": "nip",
        "aliases": [
          "Nip",
          "nip"
        ],
        "extensions": [
          ".nip"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nip",
        "scopeName": "source.nip",
        "path": "./syntaxes/nip.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "nip",
        "path": "./snippits/snippits.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "package": "pnpm run check-types && pnpm run lint && tsc -p .",
    "compile": "pnpm run check-types && pnpm run lint && tsc .",
    "watch": "tsc -watch -p .",
    "build": "vsce package",
    "check-types": "tsc --noEmit",
    "lint": "biome check --write .",
    "release": "release-it",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^22.11.13",
    "@types/vscode": "1.84.2",
    "@vscode/vsce": "^3.9.1",
    "release-it": "^19.2.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
