{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "commitMessage": "Release ${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "assets": ["*.vsix"]
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": "pnpm run check-types && pnpm run lint && tsc -p . && pnpm exec vsce package"
  }
}
